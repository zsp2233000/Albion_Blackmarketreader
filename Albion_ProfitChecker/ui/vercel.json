    },
    {
      "source": "/dashboard.html",
      "destination": "/dashboard",
      "permanent": true
    },
    {
      "source": "/community/index.html",
      "destination": "/community",
      "permanent": true
    },
    {
      "source": "/legal/index.html",
      "destination": "/legal",
      "permanent": true
    },
    {
      "source": "/Blackmarket-Crafter",
      "destination": "/bm-crafter",
