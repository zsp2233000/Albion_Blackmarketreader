{
  "framework": "vite",
  "installCommand": "cd Albion_ProfitChecker/ui && npm install",
  "buildCommand": "cd Albion_ProfitChecker/ui && npm run build",
  "outputDirectory": "Albion_ProfitChecker/ui/dist",
  "redirects": [
    {
      "source": "/premium-plus",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/premium-plus/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/Crafting%20Calculator",
      "destination": "/crafting-calculator",
      "permanent": true
    },
    {
      "source": "/dashboard.html",
      "destination": "/dashboard",
      "permanent": true
    },
    {
      "source": "/community/index.html",
      "destination": "/community",
      "permanent": true
    },
    {
      "source": "/legal/index.html",
      "destination": "/legal",
      "permanent": true
    },
    {
      "source": "/Blackmarket-Crafter",
      "destination": "/bm-crafter",
      "permanent": true
    },
    {
      "source": "/Blackmarket-Crafter/index.html",
      "destination": "/bm-crafter",
      "permanent": true
    },
    {
      "source": "/crafting-calculator/index.html",
      "destination": "/crafting-calculator",
      "permanent": true
    },
    {
      "source": "/refining-calculator/index.html",
      "destination": "/refining-calculator",
      "permanent": true
    },
    {
      "source": "/Refining%20Calculator",
      "destination": "/refining-calculator",
      "permanent": true
    },
    {
      "source": "/Refining%20Calculator/index.html",
      "destination": "/refining-calculator",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/community",
      "destination": "/index.html"
    },
    {
      "source": "/legal",
      "destination": "/index.html"
    },
    {
      "source": "/bm-crafter",
      "destination": "/index.html"
    },
    {
      "source": "/crafting-calculator",
      "destination": "/index.html"
    },
    {
      "source": "/refining-calculator",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/results(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/avg-profit-history.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/items-categorized-crafting.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/picture/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, s-maxage=2592000, immutable"
        }
      ]
    },
    {
      "source": "/itemicons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, s-maxage=2592000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
